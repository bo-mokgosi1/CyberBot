<Window x:Class="CyberBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBot - Cybersecurity Awareness Chatbot"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <Style x:Key="CyberButton" TargetType="Button">
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#388BFD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0550AE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#DA3633"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F85149"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource CyberButton}">
            <Setter Property="Background" Value="#238636"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2EA043"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CyberTab" TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8B949E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#1F6FEB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#C9D1D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#1F6FEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CyberListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style x:Key="CyberListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#C9D1D9"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1F2D47"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#21262D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" Background="#1F6FEB"
                            CornerRadius="17" Margin="0,0,12,0">
                        <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="CyberBot" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Cybersecurity Awareness Chatbot"
                               FontSize="13" Foreground="#8B949E"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="txtUserName" Text="Guest" Foreground="#8B949E"
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Ellipse Width="10" Height="10" Fill="#3FB950"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Online" Foreground="#3FB950"
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TABS -->
        <TabControl Grid.Row="1" Background="#0D1117"
                    BorderBrush="#30363D" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabPanel">
                    <Setter Property="Background" Value="#161B22"/>
                </Style>
            </TabControl.Resources>

            <!-- ═══════════════════════════════════════════ -->
            <!-- CHAT TAB                                    -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Style="{StaticResource CyberTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Chat" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#161B22" BorderBrush="#30363D"
                            BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                        <ScrollViewer x:Name="ChatScrollViewer"
                                      VerticalScrollBarVisibility="Auto" Padding="12">
                            <StackPanel x:Name="ChatPanel"/>
                        </ScrollViewer>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtChatInput"
                                 Style="{StaticResource CyberTextBox}"
                                 Height="44" VerticalContentAlignment="Center"
                                 KeyDown="TxtChatInput_KeyDown"/>
                        <Button Grid.Column="1" Style="{StaticResource CyberButton}"
                                Margin="8,0,0,0" Height="44" Width="80"
                                Click="BtnSend_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Send" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Style="{StaticResource DangerButton}"
                                Margin="8,0,0,0" Height="44" Width="80"
                                Click="BtnClearChat_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Clear" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- TASKS TAB                                   -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Style="{StaticResource CyberTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Tasks" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Task list -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="My Cybersecurity Tasks" FontSize="16"
                                   FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <ListBox x:Name="lstTasks" Grid.Row="1"
                                 Style="{StaticResource CyberListBox}"
                                 ItemContainerStyle="{StaticResource CyberListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StatusIcon}"
                                                   FontFamily="Segoe MDL2 Assets" FontSize="16"
                                                   Foreground="{Binding StatusIconColor}"
                                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="{Binding TitleColor}"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11" Foreground="#8B949E"
                                                       TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding ReminderVisibility}">
                                                <TextBlock Text="&#xEC92;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="11" Foreground="#F78166"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding ReminderText}"
                                                           FontSize="11" Foreground="#F78166"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="2" Background="{Binding StatusBg}"
                                                CornerRadius="10" Padding="8,3"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" FontSize="11"
                                                       Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Style="{StaticResource GreenButton}"
                                    Margin="0,0,8,0" Click="BtnMarkComplete_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE930;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Mark Complete" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource DangerButton}"
                                    Click="BtnDeleteTask_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Delete Task" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Add task panel -->
                    <Border Grid.Column="1" Background="#161B22" BorderBrush="#30363D"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Add New Task" FontSize="15" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,16"/>
                            <TextBlock Text="Title *" Foreground="#8B949E"
                                       FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTaskTitle"
                                     Style="{StaticResource CyberTextBox}" Margin="0,0,0,12"/>
                            <TextBlock Text="Description" Foreground="#8B949E"
                                       FontSize="12" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtTaskDesc"
                                     Style="{StaticResource CyberTextBox}"
                                     Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                            <TextBlock Text="Reminder Date (optional)" Foreground="#8B949E"
                                       FontSize="12" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpReminder" Margin="0,0,0,16"
                                        Background="#161B22" Foreground="#C9D1D9"
                                        BorderBrush="#30363D"/>
                            <Button Style="{StaticResource CyberButton}"
                                    Click="BtnAddTask_Click" Height="40">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Add Task" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Separator Background="#30363D" Margin="0,16"/>
                            <TextBlock Text="Quick Add" Foreground="#8B949E"
                                       FontSize="12" Margin="0,0,0,8"/>
                            <WrapPanel>
                                <Button Style="{StaticResource CyberButton}"
                                        Margin="0,0,6,6" FontSize="11" Padding="8,5"
                                        Content="2FA Setup"
                                        Tag="Enable two-factor authentication"
                                        Click="BtnQuickTask_Click"/>
                                <Button Style="{StaticResource CyberButton}"
                                        Margin="0,0,6,6" FontSize="11" Padding="8,5"
                                        Content="Password Review"
                                        Tag="Review account passwords"
                                        Click="BtnQuickTask_Click"/>
                                <Button Style="{StaticResource CyberButton}"
                                        Margin="0,0,6,6" FontSize="11" Padding="8,5"
                                        Content="Privacy Check"
                                        Tag="Review account privacy settings"
                                        Click="BtnQuickTask_Click"/>
                                <Button Style="{StaticResource CyberButton}"
                                        Margin="0,0,6,6" FontSize="11" Padding="8,5"
                                        Content="Backup Data"
                                        Tag="Backup important data"
                                        Click="BtnQuickTask_Click"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- QUIZ TAB                                    -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Style="{StaticResource CyberTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Quiz" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">

                    <!-- Start screen -->
                    <StackPanel x:Name="QuizStartPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="80" Height="80" Background="#1F6FEB"
                                CornerRadius="40" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="40" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Cybersecurity Mini-Game" FontSize="28"
                                   FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Test your knowledge with 10 cybersecurity questions!"
                                   FontSize="14" Foreground="#8B949E"
                                   HorizontalAlignment="Center" Margin="0,0,0,32"/>
                        <Button Style="{StaticResource CyberButton}"
                                HorizontalAlignment="Center" Width="180" Height="50"
                                Click="BtnStartQuiz_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Start Quiz" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Quiz play screen -->
                    <Grid x:Name="QuizPlayPanel" Visibility="Collapsed"
                          MaxWidth="700" HorizontalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="txtQuizProgress" Text="Question 1 of 10"
                                           Foreground="#8B949E" FontSize="13"/>
                                <ProgressBar x:Name="QuizProgress" Height="6" Margin="0,6,0,0"
                                             Background="#21262D" Foreground="#1F6FEB"
                                             BorderThickness="0" Maximum="10" Value="1"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" x:Name="txtQuizScore" Text="Score: 0"
                                       Foreground="#3FB950" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="10"
                                Padding="24,20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock x:Name="txtQuizType" Text="MULTIPLE CHOICE"
                                           Foreground="#1F6FEB" FontSize="11"
                                           FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock x:Name="txtQuestion" FontSize="16"
                                           Foreground="White" TextWrapping="Wrap" LineHeight="24"/>
                            </StackPanel>
                        </Border>

                        <StackPanel x:Name="AnswersPanel" Grid.Row="2" Margin="0,0,0,16"/>

                        <Border x:Name="FeedbackBorder" Grid.Row="3" CornerRadius="8"
                                Padding="16,12" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="txtFeedback" FontSize="14"
                                           FontWeight="SemiBold" Foreground="White"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="txtFeedbackExplanation" FontSize="13"
                                           Foreground="#C9D1D9" TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                                <Button x:Name="btnNextQuestion"
                                        Style="{StaticResource CyberButton}"
                                        Margin="0,12,0,0" HorizontalAlignment="Right"
                                        Click="BtnNextQuestion_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Next Question"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="&#xE76C;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Results screen -->
                    <StackPanel x:Name="QuizResultPanel" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="90" Height="90" Background="#1F6FEB"
                                CornerRadius="45" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <TextBlock x:Name="txtResultIcon" Text="&#xE734;"
                                       FontFamily="Segoe MDL2 Assets" FontSize="44"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock x:Name="txtResultTitle" FontSize="26" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtResultScore" FontSize="48" FontWeight="Bold"
                                   Foreground="#1F6FEB" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="txtResultFeedback" FontSize="15"
                                   Foreground="#8B949E" HorizontalAlignment="Center"
                                   Margin="0,8,0,32" TextWrapping="Wrap"
                                   MaxWidth="400" TextAlignment="Center"/>
                        <Button Style="{StaticResource CyberButton}"
                                HorizontalAlignment="Center" Width="160" Height="46"
                                Click="BtnPlayAgain_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Play Again" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- NLP TAB                                     -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Style="{StaticResource CyberTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="NLP Assistant" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="NLP-Powered Assistant" FontSize="16"
                                   FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                        <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="8" Margin="0,0,0,12">
                            <ScrollViewer x:Name="NlpScrollViewer"
                                          VerticalScrollBarVisibility="Auto" Padding="12">
                                <StackPanel x:Name="NlpChatPanel"/>
                            </ScrollViewer>
                        </Border>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtNlpInput"
                                     Style="{StaticResource CyberTextBox}"
                                     Height="44" VerticalContentAlignment="Center"
                                     KeyDown="TxtNlpInput_KeyDown"/>
                            <Button Grid.Column="1" Style="{StaticResource CyberButton}"
                                    Margin="8,0,0,0" Height="44" Width="80"
                                    Click="BtnNlpSend_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Ask" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>

                    <Border Grid.Column="1" Background="#161B22" BorderBrush="#30363D"
                            BorderThickness="1" CornerRadius="8" Padding="16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="16" Foreground="White"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Try saying..." FontSize="14"
                                           FontWeight="Bold" Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Tasks" Foreground="#1F6FEB"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Add a task to enable 2FA"
                                       Foreground="#8B949E" FontSize="11"
                                       Margin="0,0,0,4" TextWrapping="Wrap"/>
                            <TextBlock Text="Remind me to update my password"
                                       Foreground="#8B949E" FontSize="11"
                                       Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <TextBlock Text="Quiz" Foreground="#1F6FEB"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Start the quiz" Foreground="#8B949E"
                                       FontSize="11" Margin="0,0,0,12"/>
                            <TextBlock Text="Tips" Foreground="#1F6FEB"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Tell me about phishing"
                                       Foreground="#8B949E" FontSize="11"
                                       Margin="0,0,0,12" TextWrapping="Wrap"/>
                            <TextBlock Text="Log" Foreground="#1F6FEB"
                                       FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBlock Text="Show activity log" Foreground="#8B949E"
                                       FontSize="11" Margin="0,0,0,16"/>
                            <Separator Background="#30363D" Margin="0,0,0,12"/>
                            <TextBlock Text="Detected intent:" Foreground="#8B949E"
                                       FontSize="12" Margin="0,0,0,6"/>
                            <Border Background="#0D1117" CornerRadius="6" Padding="10,8">
                                <TextBlock x:Name="txtDetectedIntent" Text="—"
                                           Foreground="#3FB950" FontSize="12"
                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════ -->
            <!-- ACTIVITY LOG TAB                            -->
            <!-- ═══════════════════════════════════════════ -->
            <TabItem Style="{StaticResource CyberTab}">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Activity Log" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Activity Log" FontSize="16"
                                       FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="txtLogCount" Text="Showing last 10 actions"
                                       Foreground="#8B949E" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="btnToggleLog" Content="Show All"
                                    Style="{StaticResource CyberButton}"
                                    Margin="0,0,8,0" Click="BtnShowAllLog_Click"
                                    FontSize="12" Padding="10,6"/>
                            <Button Style="{StaticResource DangerButton}"
                                    Click="BtnClearLog_Click" FontSize="12" Padding="10,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clear Log" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#161B22" BorderBrush="#30363D"
                            BorderThickness="1" CornerRadius="8">
                        <ListBox x:Name="lstActivityLog"
                                 Style="{StaticResource CyberListBox}"
                                 BorderThickness="0"
                                 ItemContainerStyle="{StaticResource CyberListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{Binding IconBg}" CornerRadius="6"
                                                Width="32" Height="32" Margin="0,0,12,0">
                                            <TextBlock Text="{Binding Icon}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="15" Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Action}"
                                                       Foreground="White" FontSize="13"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Detail}"
                                                       Foreground="#8B949E" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Timestamp}"
                                                   Foreground="#8B949E" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <!-- Stats -->
                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="8"
                                Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="&#xE8F9;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" Foreground="#1F6FEB"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock x:Name="statTasks" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#1F6FEB"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Tasks Active" Foreground="#8B949E"
                                           FontSize="12" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="8"
                                Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" Foreground="#3FB950"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock x:Name="statQuiz" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#3FB950"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Quizzes Taken" Foreground="#8B949E"
                                           FontSize="12" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="8"
                                Padding="16,12" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" Foreground="#F78166"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock x:Name="statChat" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#F78166"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Chat Messages" Foreground="#8B949E"
                                           FontSize="12" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Background="#161B22" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="8" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="&#xE9CE;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="20" Foreground="#D2A8FF"
                                           HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock x:Name="statNlp" Text="0" FontSize="22"
                                           FontWeight="Bold" Foreground="#D2A8FF"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="NLP Interactions" Foreground="#8B949E"
                                           FontSize="12" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
